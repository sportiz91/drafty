# --- Auth ---
# Required. At least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=
# Optional. Access token lifetime (jsonwebtoken format). Default: 15m
JWT_ACCESS_TOKEN_EXPIRY=15m

# Optional. Set true on HTTPS deploys so auth cookies carry the Secure flag.
# Default: false (the assignment runs on http://localhost)
COOKIE_SECURE=false

# --- Database ---
# Optional. SQLite file path. Default: ./data/drafty.db
DATABASE_PATH=./data/drafty.db
