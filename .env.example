# --- Auth ---
# Required. At least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=
# Optional. Access token lifetime (jsonwebtoken format). Default: 15m
JWT_ACCESS_TOKEN_EXPIRY=15m

# Optional. Set true on HTTPS deploys so auth cookies carry the Secure flag.
# Default: false (the assignment runs on http://localhost)
COOKIE_SECURE=false

# Optional. Disables API rate limiting (the e2e suite sets this; never in prod).
# Default: false
RATE_LIMIT_DISABLED=false

# --- Stripe (TEST MODE keys only — never live keys) ---
# Required for billing. From https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# From `stripe listen --print-secret` (local) or the Dashboard webhook config
STRIPE_WEBHOOK_SECRET=
# The recurring Price id of the single paid plan (price_...)
STRIPE_PRICE_ID=

# --- Database ---
# Optional. SQLite file path. Default: ./data/drafty.db
DATABASE_PATH=./data/drafty.db
